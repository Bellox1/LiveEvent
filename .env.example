-- =========================
-- 1. CLEANUP (SUPPRESSION DE L'EXISTANT)
-- =========================
drop policy if exists "read events" on public.events;
drop policy if exists "create events" on public.events;
drop policy if exists "read participants" on public.participants;
drop policy if exists "join event" on public.participants;
drop policy if exists "leave event" on public.participants;
drop policy if exists "read profiles" on public.profiles;

drop trigger if exists on_auth_user_created on auth.users;
drop function if exists public.handle_new_user;

drop table if exists public.participants cascade;
drop table if exists public.events cascade;
drop table if exists public.profiles cascade;

-- =========================
-- 2. CRÉATION DES PROFILS
-- =========================
CREATE TABLE public.profiles (
  id uuid PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
  email text NOT NULL
);

ALTER TABLE public.profiles ENABLE ROW LEVEL SECURITY;
CREATE POLICY "read profiles" ON public.profiles FOR SELECT USING (true);

INSERT INTO public.profiles (id, email)
SELECT id, email FROM auth.users;

-- =========================
-- 3. TRIGGER POUR NOUVEAUX INSCRITS
-- =========================
CREATE OR REPLACE FUNCTION public.handle_new_user()
RETURNS trigger AS $$
BEGIN
  INSERT INTO public.profiles (id, email)
  VALUES (new.id, new.email);
  RETURN new;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE PROCEDURE public.handle_new_user();

-- =========================
-- 4. CRÉATION DES ÉVÉNEMENTS (Lié à Profiles)
-- =========================
create table public.events (
  id uuid primary key default gen_random_uuid(),
  title text not null,
  date timestamp not null,
  created_by uuid references public.profiles(id) on delete cascade,
  created_at timestamp default now()
);

-- =========================
-- 5. CRÉATION PARTICIPANTS (Lié à Profiles)
-- =========================
create table public.participants (
  id uuid primary key default gen_random_uuid(),
  user_id uuid references public.profiles(id) on delete cascade,
  event_id uuid references public.events(id) on delete cascade,
  created_at timestamp default now()
);

-- =========================
-- 6. SÉCURITÉ & POLICIES (RLS)
-- =========================
alter table public.events enable row level security;
alter table public.participants enable row level security;

create policy "read events" on public.events for select using (true);
create policy "create events" on public.events for insert with check (auth.uid() = created_by);

create policy "read participants" on public.participants for select using (true);
create policy "join event" on public.participants for insert with check (auth.uid() = user_id);
create policy "leave event" on public.participants for delete using (auth.uid() = user_id);

-- =========================
-- 7. RECHARGEMENT DU CACHE
-- =========================
NOTIFY pgrst, 'reload schema';
