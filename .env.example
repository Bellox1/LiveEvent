-- =========================
-- SUPPRIMER TRIGGER + FUNCTION
-- =========================
drop trigger if exists on_auth_user_created on auth.users;
drop function if exists public.handle_new_user;

-- =========================
-- SUPPRIMER TABLES
-- =========================
drop table if exists public.participants cascade;
drop table if exists public.events cascade;
drop table if exists public.users cascade;

-- =========================
-- VIDER auth.users (⚠️ DEV UNIQUEMENT)
-- =========================
delete from auth.users;

-- =========================
-- RECREER EVENTS (lié directement à auth.users)
-- =========================
create table public.events (
  id uuid primary key default gen_random_uuid(),
  title text not null,
  date timestamp not null,
  created_by uuid references auth.users(id) on delete cascade,
  created_at timestamp default now()
);

-- =========================
-- RECREER PARTICIPANTS (lié directement à auth.users)
-- =========================
create table public.participants (
  id uuid primary key default gen_random_uuid(),
  user_id uuid references auth.users(id) on delete cascade,
  event_id uuid references public.events(id) on delete cascade,
  created_at timestamp default now()
);

-- =========================
-- ACTIVER RLS
-- =========================
alter table public.events enable row level security;
alter table public.participants enable row level security;

-- =========================
-- POLICIES EVENTS
-- =========================
create policy "read events"
on public.events for select
using (true);

create policy "create events"
on public.events for insert
with check (auth.uid() = created_by);

-- =========================
-- POLICIES PARTICIPANTS
-- =========================
create policy "read participants"
on public.participants for select
using (true);

create policy "join event"
on public.participants for insert
with check (auth.uid() = user_id);

create policy "leave event"
on public.participants for delete
using (auth.uid() = user_id);